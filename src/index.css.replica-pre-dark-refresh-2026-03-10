@import "tailwindcss";

@theme {
  --font-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
}

:root {
  --bg: #050505;
  --ink: #ffffff;
  --accent: #ff4e00;
  --dot-empty: #1a1a1a;
  --dot-filled: #333333;
  --dot-highlight: #3b82f6;
  --dot-stat: #4ade80;
  --card-bg: rgba(24, 24, 27, 0.5);
  --border: rgba(255, 255, 255, 0.05);
  --input-bg: rgba(0, 0, 0, 0.4);
  --input-border: rgba(255, 255, 255, 0.1);
  --scrollbar-thumb: #222;
  --scrollbar-hover: #333;
}

[data-theme="light"] {
  --bg: #f5f5f5;
  --ink: #0a0a0a;
  --accent: #ff4e00;
  --dot-empty: #e5e5e5;
  --dot-filled: #a1a1aa;
  --card-bg: rgba(255, 255, 255, 0.8);
  --border: rgba(0, 0, 0, 0.05);
  --input-bg: rgba(255, 255, 255, 0.6);
  --input-border: rgba(0, 0, 0, 0.1);
  --scrollbar-thumb: #ccc;
  --scrollbar-hover: #bbb;
}

body {
  background-color: var(--bg);
  color: var(--ink);
  font-family: var(--font-sans);
  margin: 0;
  overflow: hidden;
  transition: background-color 0.3s ease, color 0.3s ease;
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(100, 1fr);
  gap: 3px;
  width: fit-content;
  margin: 0 auto;
}

.dot {
  width: 8px;
  height: 8px;
  border-radius: 2px;
  transition: all 0.2s ease;
}

.dot::before {
  content: "";
  position: absolute;
  inset: -5px;
}

@media (max-height: 900px) {
  .dot {
    width: 6px;
    height: 6px;
  }
  .grid-container {
    gap: 2px;
  }
}

@media (max-width: 1200px) {
  .grid-container {
    grid-template-columns: repeat(100, 1fr);
    gap: 2px;
  }
  .dot {
    width: 5px;
    height: 5px;
  }
}

@media (max-width: 768px) {
  .grid-container {
    grid-template-columns: repeat(100, 1fr);
    gap: 1.5px;
  }
  .dot {
    width: 3px;
    height: 3px;
  }

  .dot::before {
    inset: -6px;
  }
}

.dot-empty {
  background-color: var(--dot-empty);
}

.dot-filled {
  background-color: var(--dot-filled);
}

.dot-current {
  background-color: var(--accent);
  box-shadow: 0 0 15px var(--accent), 0 0 30px var(--accent);
}

.dot-highlighted {
  background-color: var(--dot-highlight) !important;
}

.dot-stat {
  background-color: var(--dot-stat);
  opacity: 0.6;
}

.dot-has-journal {
  box-shadow: 0 0 4px var(--ink);
  border: 1px solid var(--input-border);
}

/* Custom scrollbar for a clean look */
::-webkit-scrollbar {
  width: 4px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: var(--scrollbar-thumb);
  border-radius: 10px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--scrollbar-hover);
}
