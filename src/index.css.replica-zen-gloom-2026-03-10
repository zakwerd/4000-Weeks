@import "tailwindcss";

@theme {
  --font-sans: "Avenir Next", "Segoe UI", "Noto Sans", "Helvetica Neue", Arial, sans-serif;
  --font-serif: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
}

:root {
  --bg: #10131a;
  --ink: #e7e2d6;
  --accent: #d56b3b;
  --dot-empty: #252a34;
  --dot-filled: #454b58;
  --dot-highlight: #7c90b8;
  --dot-stat: #6b8a72;
  --card-bg: rgba(24, 28, 37, 0.62);
  --border: rgba(227, 220, 202, 0.09);
  --input-bg: rgba(12, 15, 22, 0.55);
  --input-border: rgba(227, 220, 202, 0.16);
  --scrollbar-thumb: #2d3240;
  --scrollbar-hover: #3a4252;
}

[data-theme="light"] {
  --bg: #f5f5f5;
  --ink: #0a0a0a;
  --accent: #ff4e00;
  --dot-empty: #e5e5e5;
  --dot-filled: #a1a1aa;
  --card-bg: rgba(255, 255, 255, 0.8);
  --border: rgba(0, 0, 0, 0.05);
  --input-bg: rgba(255, 255, 255, 0.6);
  --input-border: rgba(0, 0, 0, 0.1);
  --scrollbar-thumb: #ccc;
  --scrollbar-hover: #bbb;
}

body {
  background-color: var(--bg);
  background-image:
    radial-gradient(1200px at 20% -10%, #1b202b 0%, transparent 55%),
    radial-gradient(900px at 100% 0%, #171b24 0%, transparent 50%),
    linear-gradient(180deg, #12151c 0%, #0f1116 100%);
  color: var(--ink);
  font-family: var(--font-sans);
  margin: 0;
  overflow: hidden;
  transition: background-color 0.3s ease, color 0.3s ease;
}

.serif {
  font-family: var(--font-serif);
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(100, 1fr);
  gap: 3px;
  width: fit-content;
  margin: 0 auto;
}

.dot {
  width: 8px;
  height: 8px;
  border-radius: 2px;
  transition: all 0.2s ease;
}

.dot::before {
  content: "";
  position: absolute;
  inset: -5px;
}

@media (max-height: 900px) {
  .dot {
    width: 6px;
    height: 6px;
  }
  .grid-container {
    gap: 2px;
  }
}

@media (max-width: 1200px) {
  .grid-container {
    grid-template-columns: repeat(100, 1fr);
    gap: 2px;
  }
  .dot {
    width: 5px;
    height: 5px;
  }
}

@media (max-width: 768px) {
  .grid-container {
    grid-template-columns: repeat(100, 1fr);
    gap: 1.5px;
  }
  .dot {
    width: 3px;
    height: 3px;
  }

  .dot::before {
    inset: -6px;
  }
}

.dot-empty {
  background-color: var(--dot-empty);
}

.dot-filled {
  background-color: var(--dot-filled);
}

.dot-current {
  background-color: var(--accent);
  box-shadow: 0 0 15px var(--accent), 0 0 30px var(--accent);
}

.dot-highlighted {
  background-color: var(--dot-highlight) !important;
}

.dot-stat {
  background-color: var(--dot-stat);
  opacity: 0.6;
}

.dot-has-journal {
  box-shadow: 0 0 4px var(--ink);
  border: 1px solid var(--input-border);
}

/* Custom scrollbar for a clean look */
::-webkit-scrollbar {
  width: 4px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: var(--scrollbar-thumb);
  border-radius: 10px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--scrollbar-hover);
}
